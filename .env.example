# Web server
WEB_PORT=8000
LOG_LEVEL=INFO
BASE_PATH=  # Leave empty for root deployment, set to /aitools for subdirectory
SERVICE_URL_WEB=https://drose.io/aitools

# Storage backend: "minio" in production, "local" for development
AITOOLS_STORAGE_BACKEND=local
AITOOLS_LOCAL_DATA_DIR=dev_cache
TOOLS_FILE=
AITOOLS_SLUG_REGISTRY_FILE=

# MinIO settings (required when AITOOLS_STORAGE_BACKEND=minio)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=aitools
MINIO_PUBLIC_URL=https://minio.drose.io

# Umami analytics
UMAMI_WEBSITE_ID=
UMAMI_SCRIPT_SRC=https://analytics.drose.io/script.js
UMAMI_DOMAINS=drose.io
UMAMI_DROSE_ID=33e9b5a0-5fbf-474c-9d60-9bee34d577bd

# Legacy discovery/editorial/comparison settings.
# These are only needed when intentionally running the old LLM-heavy modules.
OPENAI_API_KEY=
OPENAI_BASE_URL=
TAVILY_API_KEY=
CONTENT_ENHANCER_MODEL=gpt-5-mini
SEARCH_MODEL=gpt-5-mini
MAINTENANCE_MODEL=gpt-5
WEB_SEARCH_MODEL=gpt-5
COMPARISON_DETECTOR_MODEL=gpt-5-mini
COMPARISON_GENERATOR_MODEL=gpt-5-mini

# Optional legacy module tuning
CONTENT_ENHANCER_MAX_PER_RUN=50
CONTENT_ENHANCER_STALE_DAYS=7
COMPARISON_DETECTOR_MAX_COMPARISONS=50
COMPARISON_DETECTOR_STALE_DAYS=30
COMPARISON_GENERATOR_MAX_PER_RUN=10
COMPARISON_GENERATOR_STALE_DAYS=7
